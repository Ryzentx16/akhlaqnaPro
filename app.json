{
  "expo": {
    "owner": "ryzentx",
    "name": "Amanti",
    "slug": "akhlaqna",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ]
    ],
    "splash": {
      "image": "./assets/Eshrhli_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#660032"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/647986a9-70ce-4870-98be-b9c06240715c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryzentx.amanti"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Eshrhli_Adaptive.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.ryzentx.amanti",
      "versionCode": 9,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "647986a9-70ce-4870-98be-b9c06240715c"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
